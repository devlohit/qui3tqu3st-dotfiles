{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 0,
        
    "modules-left": [
        "custom/arch",
        "wlr/taskbar",
    ],

    "modules-center": [
        "clock",
        "hyprland/workspaces",
        "pulseaudio",
        "network",
        "bluetooth",
        "tray",
        "battery",
        "custom/power",
        "power-profiles-daemon",
    ],

    "custom/arch": {
        "format": "{}",
        "exec": "echo '󰣇'",
        "interval": "once",
        "tooltip": false,
        "on-click": "vicinae toggle"
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "Alacritty"
        ],
        "app_ids-mapping": {
           "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
           "Firefox Web Browser": "Firefox",
           "Foot Server": "Terminal"
        }
    },
        
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d, %Y (%H:%M)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#f5e0dc'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'>{}</span>",
                "weeks": "<span color='#94e2d5'><b>W{}</b></span>",
                "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
                "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
            }
        }
    },
   
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 4 
        },
        "format-icons": {
            "active": "",
            "default": ""
        }
    },
    
    "cpu": {
        "interval": 10,
        "format": "󰻠   {usage}%",
        "max-length": 10,
        "on-click": "kitty -e btop"
    },
    
    "memory": {
        "interval": 30,
        "format": "󰍛   {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e btop"
    },
    
    "pulseaudio": {
        "format": "󰕾",
        "format-muted": "󰝟",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "{icon}",
        "format-disabled": "󰂲",
        "format-off": "󰂲",
        "format-on": "",
        "format-connected": "󰂱",
        "format-icons": {
            "enabled": "󰂯",
            "disabled": "󰂲"
        },
        "tooltip-format": "󰂯  {status}",
        "tooltip-format-connected": "󰂱  {device_alias}\n  {num_connections} connected",
        "on-click": "blueman-manager"
    },
    
    "network": {
        "interval": 3,
        "format-wifi": "{icon}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰤮",
        "format-icons": {
            "wifi": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"]
        },
        "tooltip-format-wifi": "󰤨  {essid}\n  Signal: {signalStrength}%\n  IP: {ipaddr}",
        "tooltip-format-ethernet": "󰈀  Ethernet\n  IP: {ipaddr}",
        "tooltip-format-disconnected": "󰤮  Disconnected",
        "on-click": "kitty --title nmtui -e nmtui"
    },

    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "󰂀 {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰂄 {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "max-length": 25
    },
    
    "tray": {
        "icon-size": 17,
        "spacing": 10,
        "show-passive-items": true,
        "smooth-scrolling-threshold": 1.0
    },
    
    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "wlogout -l ~/.config/wlogout/layout -b 5 -c 5 -r 1 --margin-top 400 --margin-bottom 400"
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "󱐋",
            "performance": "󱐋",
            "balanced": "",
            "power-saver": "󰌪"
        }
    },
}
