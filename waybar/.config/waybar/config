{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 0,
        
    "modules-center": [
        "clock",
        "hyprland/workspaces",
        "pulseaudio",
        "network",
        "bluetooth",
        "tray",
        "battery",
        "custom/power",
        "power-profiles-daemon",
    ],
        
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d, %Y (%H:%M)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#f5e0dc'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'>{}</span>",
                "weeks": "<span color='#94e2d5'><b>W{}</b></span>",
                "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
                "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
            }
        }
    },
   
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 4 
        },
        "format-icons": {
            "active": "",
            "default": ""
        }
    },
    
    "cpu": {
        "interval": 10,
        "format": "¾░╗Ā   {usage}%",
        "max-length": 10,
        "on-click": "kitty -e btop"
    },
    
    "memory": {
        "interval": 30,
        "format": "¾░Źø   {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e btop"
    },
    
    "pulseaudio": {
        "format": "¾░ĢŠ",
        "format-muted": "¾░Ø¤",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "{icon}",
        "format-disabled": "¾░é▓",
        "format-off": "¾░é▓",
        "format-on": "’Ŗö",
        "format-connected": "¾░é▒",
        "format-icons": {
            "enabled": "¾░é»",
            "disabled": "¾░é▓"
        },
        "tooltip-format": "¾░é»  {status}",
        "tooltip-format-connected": "¾░é▒  {device_alias}\n  {num_connections} connected",
        "on-click": "blueman-manager"
    },
    
    "network": {
        "interval": 3,
        "format-wifi": "{icon}",
        "format-ethernet": "¾░łĆ",
        "format-disconnected": "¾░ż«",
        "format-icons": {
            "wifi": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"]
        },
        "tooltip-format-wifi": "¾░ż©  {essid}\n  Signal: {signalStrength}%\n  IP: {ipaddr}",
        "tooltip-format-ethernet": "¾░łĆ  Ethernet\n  IP: {ipaddr}",
        "tooltip-format-disconnected": "¾░ż«  Disconnected",
        "on-click": "kitty --title nmtui -e nmtui"
    },

    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "¾░éĆ  {capacity}%",
        "format-charging": "¾░éä  {capacity}%",
        "format-plugged": "¾░éä  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "max-length": 25
    },
    
    "tray": {
        "icon-size": 17,
        "spacing": 10,
        "smooth-scrolling-threshold": 1.0
    },
    
    "custom/power": {
        "format": "ŌÅ╗",
        "tooltip": false,
        "on-click": "wlogout -l ~/.config/wlogout/layout -b 5 -c 5 -r 1 --margin-top 400 --margin-bottom 400"
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "¾▒Éŗ",
            "performance": "¾▒Éŗ",
            "balanced": "Ņ╗®",
            "power-saver": "¾░ī¬"
        }
    },
}
